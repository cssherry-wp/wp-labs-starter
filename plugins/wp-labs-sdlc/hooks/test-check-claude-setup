#!/usr/bin/env bash
set -euo pipefail

command -v jq > /dev/null || { echo 'SKIP: jq not found'; exit 0; }

HOOK="$(cd "$(dirname "$0")" && pwd)/check-claude-setup"
TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

# --- Helpers ---
pass() { printf 'PASS: %s\n' "$1"; }
fail() { printf 'FAIL: %s\n' "$1"; exit 1; }
# run_hook: pipe JSON stdin so the hook's `cat` doesn't block
run_hook() { echo "${1:-{\}}" | bash "$HOOK" "${@:2}"; }

# --- Setup mock plugin root ---
PLUGIN_ROOT="$TMP/plugin"
TMPL="$PLUGIN_ROOT/skills/scaffolding-sdlc/templates/claude"
mkdir -p "$TMPL/rules"
printf '# CLAUDE\n' > "$TMPL/CLAUDE.md"
printf '#!/usr/bin/env bash\necho hi\n' > "$TMPL/statusline.sh"
printf 'rule content\n' > "$TMPL/rules/coding.md"
printf '{"defaultMode":"plan","enabledPlugins":{"foo":true}}\n' > "$TMPL/settings.json"

# Mock q script (no-op migrate so tests don't need a real queue dir)
mkdir -p "$PLUGIN_ROOT/skills/queue"
printf '#!/usr/bin/env bash\nexit 0\n' > "$PLUGIN_ROOT/skills/queue/q"
chmod +x "$PLUGIN_ROOT/skills/queue/q"

# --- Test 1: clean (all files match) -> silent ---
LOCAL="$TMP/clean"
mkdir -p "$LOCAL/rules"
cp "$TMPL/CLAUDE.md" "$LOCAL/CLAUDE.md"
cp "$TMPL/statusline.sh" "$LOCAL/statusline.sh"
cp "$TMPL/rules/coding.md" "$LOCAL/rules/coding.md"
printf '{"defaultMode":"plan","enabledPlugins":{"foo":true},"personalKey":"x"}\n' > "$LOCAL/settings.json"

out=$(CLAUDE_PLUGIN_ROOT="$PLUGIN_ROOT" CLAUDE_CONFIG_DIR="$LOCAL" run_hook '{}' 2>/dev/null || true)
[ -z "$out" ] && pass "clean -> silent" || fail "clean -> expected no output, got: $out"

# --- Test 2: CLAUDE.md differs -> JSON listing it ---
LOCAL="$TMP/drift_claudemd"
mkdir -p "$LOCAL/rules"
printf '# OLD\n' > "$LOCAL/CLAUDE.md"
cp "$TMPL/statusline.sh" "$LOCAL/statusline.sh"
cp "$TMPL/rules/coding.md" "$LOCAL/rules/coding.md"
printf '{"defaultMode":"plan","enabledPlugins":{"foo":true}}\n' > "$LOCAL/settings.json"

out=$(CLAUDE_PLUGIN_ROOT="$PLUGIN_ROOT" CLAUDE_CONFIG_DIR="$LOCAL" run_hook '{}' 2>/dev/null || true)
echo "$out" | jq -e '.hookSpecificOutput.additionalContext | test("CLAUDE.md")' > /dev/null \
  && pass "CLAUDE.md drift -> JSON" || fail "CLAUDE.md drift -> expected CLAUDE.md in output, got: $out"

# --- Test 3: missing file -> JSON listing it as missing ---
LOCAL="$TMP/missing"
mkdir -p "$LOCAL/rules"
cp "$TMPL/CLAUDE.md" "$LOCAL/CLAUDE.md"
# statusline.sh intentionally absent
cp "$TMPL/rules/coding.md" "$LOCAL/rules/coding.md"
printf '{"defaultMode":"plan","enabledPlugins":{"foo":true}}\n' > "$LOCAL/settings.json"

out=$(CLAUDE_PLUGIN_ROOT="$PLUGIN_ROOT" CLAUDE_CONFIG_DIR="$LOCAL" run_hook '{}' 2>/dev/null || true)
echo "$out" | jq -e '.hookSpecificOutput.additionalContext | test("statusline.sh")' > /dev/null \
  && pass "missing file -> JSON" || fail "missing file -> expected statusline.sh in output, got: $out"

# --- Test 4: settings.json drift -> JSON listing it ---
LOCAL="$TMP/drift_settings"
mkdir -p "$LOCAL/rules"
cp "$TMPL/CLAUDE.md" "$LOCAL/CLAUDE.md"
cp "$TMPL/statusline.sh" "$LOCAL/statusline.sh"
cp "$TMPL/rules/coding.md" "$LOCAL/rules/coding.md"
printf '{"defaultMode":"autorespond","enabledPlugins":{"foo":true}}\n' > "$LOCAL/settings.json"

out=$(CLAUDE_PLUGIN_ROOT="$PLUGIN_ROOT" CLAUDE_CONFIG_DIR="$LOCAL" run_hook '{}' 2>/dev/null || true)
echo "$out" | jq -e '.hookSpecificOutput.additionalContext | test("settings.json")' > /dev/null \
  && pass "settings.json drift -> JSON" || fail "settings.json drift -> expected settings.json in output, got: $out"

# --- Test 5: CLAUDE_PLUGIN_ROOT unset -> silent exit ---
out=$(CLAUDE_CONFIG_DIR="$TMP/clean" run_hook '{}' 2>/dev/null || true)
[ -z "$out" ] && pass "CLAUDE_PLUGIN_ROOT unset -> silent" || fail "CLAUDE_PLUGIN_ROOT unset -> expected no output, got: $out"

# --- Test 6: stale queue file (30+ days) deleted; fresh one kept ---
LOCAL="$TMP/queue"
mkdir -p "$LOCAL/queue"
printf 'stale\n' > "$LOCAL/queue/old.md"
printf 'fresh\n' > "$LOCAL/queue/new.md"
touch -t 202001010000 "$LOCAL/queue/old.md"

CLAUDE_CONFIG_DIR="$LOCAL" run_hook '{}' > /dev/null 2>&1 || true
if [ ! -e "$LOCAL/queue/old.md" ] && [ -f "$LOCAL/queue/new.md" ]; then
  pass "stale queue deleted, fresh kept"
else
  fail "queue cleanup -> expected old.md deleted and new.md kept"
fi

# --- Test 7: first-run sentinel blocks repeat runs ---
LOCAL="$TMP/sentinel"
mkdir -p "$LOCAL/rules" "$LOCAL/queue"
cp "$TMPL/CLAUDE.md" "$LOCAL/CLAUDE.md"
cp "$TMPL/statusline.sh" "$LOCAL/statusline.sh"
cp "$TMPL/rules/coding.md" "$LOCAL/rules/coding.md"
printf '{"defaultMode":"plan","enabledPlugins":{"foo":true}}\n' > "$LOCAL/settings.json"
# Introduce drift so we'd get output — unless sentinel blocks it
printf '# DRIFT\n' > "$LOCAL/CLAUDE.md"
SID='test-session-abc'

# First run: sentinel absent, drift should appear in output
out1=$(CLAUDE_PLUGIN_ROOT="$PLUGIN_ROOT" CLAUDE_CONFIG_DIR="$LOCAL" run_hook "{\"session_id\":\"$SID\"}" 2>/dev/null || true)
echo "$out1" | jq -e '.hookSpecificOutput.additionalContext | test("CLAUDE.md")' > /dev/null \
  && pass "first run with session_id -> drift reported" \
  || fail "first run with session_id -> expected drift output, got: $out1"

# Second run: sentinel present, output must be empty
out2=$(CLAUDE_PLUGIN_ROOT="$PLUGIN_ROOT" CLAUDE_CONFIG_DIR="$LOCAL" run_hook "{\"session_id\":\"$SID\"}" 2>/dev/null || true)
[ -z "$out2" ] && pass "second run with same session_id -> silent (sentinel)" \
  || fail "second run -> expected silent, got: $out2"

echo ""
echo "All tests passed."
