#!/usr/bin/env bash
set -euo pipefail

# UserPromptSubmit hook: runs setup checks on the first prompt of each session.
# Reads {"session_id":"...","prompt":"...",...} from stdin.

# jq required for stdin parsing and JSON output
command -v jq > /dev/null 2>&1 || exit 0

_input=$(cat)
_session_id=$(printf '%s' "$_input" | jq -r '.session_id // empty' 2>/dev/null || true)

_queue_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/queue"
_trash_dir="${CLAUDE_QUEUE_TRASH_DIR:-$HOME/.Trash}"

# First-run-only: skip subsequent prompts in the same session
if [ -n "$_session_id" ]; then
  mkdir -p "$_queue_dir"
  _sentinel="${_queue_dir}/.setup-${_session_id}"
  [ -f "$_sentinel" ] && exit 0
  touch "$_sentinel"
fi

# Queue housekeeping: trash stale files (>30 days untouched)
# ponytail: mtime-based; CLAUDE_QUEUE_TRASH_DIR override lets tests redirect trash.
if [ -d "$_queue_dir" ]; then
  mkdir -p "$_trash_dir" 2>/dev/null || true
  while IFS= read -r -d '' _qf; do
    _last_edit=$(date -r "$_qf" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "unknown")
    _dest="$_trash_dir/$(basename "$_qf")"
    mv "$_qf" "$_dest" 2>/dev/null && \
      echo "queue housekeeping: trashed $(basename "$_qf") (last edit ${_last_edit}) -> ${_dest}" >&2 || true
  done < <(find "$_queue_dir" -maxdepth 1 -type f -name '*.md' -mtime +30 -print0 2>/dev/null)
fi

[ -n "${CLAUDE_PLUGIN_ROOT:-}" ] || exit 0

_q="${CLAUDE_PLUGIN_ROOT}/skills/queue/q"

# Rename pending.md → <session-id>.md (left by /queue clear in a prior session)
if [ -f "${_queue_dir}/pending.md" ] && [ -n "$_session_id" ]; then
  "$_q" rename-pending "$_session_id" >&2 || true
fi

# Detect open items in other sessions (no migration yet — Claude will prompt the user)
_migrate_output=""
if [ -n "$_session_id" ] && [ -f "$_q" ]; then
  _pending=$("$_q" list-migrateable "$_session_id" 2>/dev/null || true)
  if [ -n "$_pending" ]; then
    _migrate_output="Open items are waiting in other sessions. IMPORTANT: before doing anything else, ask the user which sessions they want to migrate into this one. Show the list below, then ask. Do not migrate without their confirmation.

${_pending}

To migrate all: \`q migrate <session-id>\`
To migrate specific sessions: \`q migrate <session-id> <src-session-id> [...]\`"
  fi
fi

# Check for claude setup drift vs. plugin templates
CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
TMPL="${CLAUDE_PLUGIN_ROOT}/skills/scaffolding-sdlc/templates/claude"
drift_files=()

check_text_file() {
  local rel="$1" src="$TMPL/$1" dst="$CLAUDE_DIR/$1"
  [ -f "$src" ] || return 0
  if [ ! -f "$dst" ]; then
    drift_files+=("$rel (missing)")
  elif ! diff -q "$src" "$dst" > /dev/null 2>&1; then
    drift_files+=("$rel")
  fi
}

check_text_file "CLAUDE.md"
check_text_file "statusline.sh"

if [ -d "$TMPL/rules" ]; then
  for src in "$TMPL/rules/"*; do
    [ -e "$src" ] || continue
    check_text_file "rules/$(basename "$src")"
  done
fi

# settings.json: merge template into local (template wins), compare to current.
# Excludes .hooks to avoid false positives from hook ordering/duplication.
if [ -f "$TMPL/settings.json" ] && [ -f "$CLAUDE_DIR/settings.json" ]; then
  merged=$(jq -sS '(.[0] | del(.hooks)) * (.[1] | del(.hooks))' \
    "$CLAUDE_DIR/settings.json" "$TMPL/settings.json" 2>/dev/null || true)
  current=$(jq -S 'del(.hooks)' "$CLAUDE_DIR/settings.json" 2>/dev/null || true)
  [ "$merged" != "$current" ] && drift_files+=("settings.json")
fi

[ ${#drift_files[@]} -eq 0 ] && [ -z "$_migrate_output" ] && exit 0

msg=""

if [ ${#drift_files[@]} -gt 0 ]; then
  drift_list=$(printf '  - %s\n' "${drift_files[@]}")
  msg="Your ~/.claude/ setup is out of sync with the wp-labs-sdlc plugin templates.

Drifted files:
${drift_list}
IMPORTANT: At the start of this session, proactively tell the user their local Claude setup is out of sync and offer to apply the updates now — no additional command from them required. If they agree, apply each drifted file:
- Text files (CLAUDE.md, statusline.sh, rules/*): read from ${TMPL}/<file> and write to ${CLAUDE_DIR}/<file>
- settings.json: run jq -sS '.[0] as \$a | .[1] as \$b | (\$a * \$b) | .hooks = (((\$a.hooks // {} | keys) + (\$b.hooks // {} | keys) | unique) as \$keys | reduce \$keys[] as \$k ({}; . + {(\$k): ([\$a.hooks[\$k] // [], \$b.hooks[\$k] // []] | add)}))' ${CLAUDE_DIR}/settings.json ${TMPL}/settings.json and write the result to ${CLAUDE_DIR}/settings.json"
fi

if [ -n "$_migrate_output" ]; then
  msg="${msg:+$msg

}${_migrate_output}"
fi

jq -n --arg v "$msg" '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":$v}}'
