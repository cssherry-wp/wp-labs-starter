#!/usr/bin/env bash
# queue helper — deterministic file I/O for the /queue skill
# usage: q <add|list|list-other|needs-interpretation|write-interpretation|mark-done|mark-cancelled|clear|rename-pending|migrate|migrate-items> ...
set -euo pipefail

QUEUE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/queue"
mkdir -p "$QUEUE_DIR"

# Guard against path traversal via a caller-supplied session id.
# UUIDs only use alphanumerics and hyphens; nothing else is valid.
_validate_sid() {
  local sid="$1"
  [ -z "$sid" ] && return 0
  [[ "$sid" =~ ^[a-zA-Z0-9_-]+$ ]] || { printf 'Invalid session id: %s\n' "$sid" >&2; exit 1; }
}

cmd="${1:-}"; shift || true

case "$cmd" in

add)
  # q add <session-id> [--high|--med|--low] "<ask>" "<ctx>"
  SID="$1"; shift; _validate_sid "$SID"
  PRI=""
  case "${1:-}" in --high) PRI=high; shift;; --med) PRI=med; shift;; --low) PRI=low; shift;; esac
  ASK="${1:-}"; CTX="${2:-$(pwd)}"
  FILE="$QUEUE_DIR/$SID.md"
  STAMP=$(date '+%Y-%m-%d %H:%M:%S')

  FIRST=$(printf '%s' "$ASK" | head -1)
  REST=$(printf '%s' "$ASK" | tail -n +2)

  {
    printf -- '- [ ] %s\n' "$FIRST"
    if [ -n "$REST" ]; then
      while IFS= read -r ln; do
        [ -n "$ln" ] && printf '  - %s\n' "$ln"
      done <<< "$REST"
    fi
    printf '  queued: %s\n' "$STAMP"
    [ -n "$PRI" ] && printf '  priority: %s\n' "$PRI"
    printf '  ctx: %s\n' "$(basename "$CTX")"
    printf '\n'
  } >> "$FILE"

  N=$(grep -c '^\- \[ \]' "$FILE" 2>/dev/null || echo 0)
  printf 'Queued (%d in backlog) → %s\n' "$N" "$FILE"
  ;;

list)
  # q list [--oneline] [session-id]
  # --oneline: one line per item (sid prefix when no session-id given)
  # no session-id: all .md files in queue dir
  ONELINE=0
  [ "${1:-}" = "--oneline" ] && { ONELINE=1; shift; }
  SID="${1:-}"

  if [ -n "$SID" ]; then
    FILE="$QUEUE_DIR/$SID.md"
    [ -f "$FILE" ] || { echo "No queue file: $FILE"; exit 1; }
    FILES=("$FILE")
  else
    shopt -s nullglob; FILES=("$QUEUE_DIR"/*.md); shopt -u nullglob
    [ ${#FILES[@]} -eq 0 ] && { echo "No queue files."; exit 0; }
  fi

  python3 - "$ONELINE" "$SID" "${FILES[@]}" <<'PY'
import sys, re, os

oneline = sys.argv[1] == '1'
single = sys.argv[2]  # non-empty = single-session mode (preserve numbered output)
files = [f for f in sys.argv[3:] if os.path.isfile(f)]

n = 0
for path in files:
    sid = os.path.basename(path)[:-3]
    if sid == 'pending':
        continue
    text = open(path).read()
    blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)
    open_blocks = [b for b in blocks if b.startswith('- [ ]')]
    if not open_blocks:
        continue

    if not oneline and not single:
        print(f'## {sid}\n')

    for block in open_blocks:
        n += 1
        lines = block.strip().split('\n')
        ask = lines[0][6:]

        if oneline:
            pfx = f'{sid[:8]}: ' if not single else ''
            print(f'{pfx}{ask}')
            continue

        meta, sub, interp_lines, in_interp = {}, [], [], False
        for line in lines[1:]:
            s = line.strip()
            if in_interp:
                if line.startswith('    '):
                    interp_lines.append(s)
                else:
                    in_interp = False
            if s.startswith('- '):
                sub.append(s[2:])
            elif s.startswith('interpretation:'):
                interp_lines.append(s[len('interpretation:'):].strip())
                in_interp = True
            elif ': ' in s and not in_interp:
                k, v = s.split(': ', 1)
                meta[k] = v

        badge = {'high': '[H]', 'med': '[M]', 'low': '[L]'}.get(meta.get('priority', ''), '')
        pfx = f'{badge} ' if badge else ''
        print(f'{n}. {pfx}{ask}')
        for s in sub:
            print(f'   • {s}')
        print(f'   queued: {meta.get("queued", "?")}')
        if interp_lines:
            print(f'   interpretation: {" ".join(interp_lines)}')
        print()

if n == 0:
    print('No open items.')
PY
  ;;

list-other)
  # q list-other <session-id> [--oneline]
  # Lists open items from all sessions EXCEPT <session-id>, labelled with [sid8:n] refs
  SID="${1:-}"; shift || true; _validate_sid "$SID"
  ONELINE=0
  [ "${1:-}" = "--oneline" ] && { ONELINE=1; shift; }
  shopt -s nullglob; FILES=("$QUEUE_DIR"/*.md); shopt -u nullglob
  [ ${#FILES[@]} -eq 0 ] && { echo "No queue files."; exit 0; }

  python3 - "$ONELINE" "$SID" "${FILES[@]}" <<'PY'
import sys, re, os

oneline = sys.argv[1] == '1'
cur_sid = sys.argv[2]
files = [f for f in sys.argv[3:] if os.path.isfile(f)]

total = 0
for path in files:
    sid = os.path.basename(path)[:-3]
    if sid in ('pending', cur_sid):
        continue
    text = open(path).read()
    blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)
    local_open = [b for b in blocks if b.startswith('- [ ]')]
    if not local_open:
        continue

    if not oneline:
        print(f'## {sid}  ({len(local_open)} item{"s" if len(local_open)!=1 else ""})\n')

    for local_n, block in enumerate(local_open, 1):
        total += 1
        lines = block.strip().split('\n')
        ask = lines[0][6:]
        ref = f'{sid[:8]}:{local_n}'

        if oneline:
            print(f'{total}. {sid[:8]}: {ask}  [{ref}]')
            continue

        meta, sub, interp_lines, in_interp = {}, [], [], False
        for line in lines[1:]:
            s = line.strip()
            if in_interp:
                if line.startswith('    '): interp_lines.append(s)
                else: in_interp = False
            if s.startswith('- '): sub.append(s[2:])
            elif s.startswith('interpretation:'):
                interp_lines.append(s[len('interpretation:'):].strip()); in_interp = True
            elif ': ' in s and not in_interp:
                k, v = s.split(': ', 1); meta[k] = v

        badge = {'high': '[H]', 'med': '[M]', 'low': '[L]'}.get(meta.get('priority', ''), '')
        pfx = f'{badge} ' if badge else ''
        print(f'{total}. {pfx}{ask}  [{ref}]')
        for s in sub: print(f'   • {s}')
        print(f'   queued: {meta.get("queued", "?")}')
        if interp_lines: print(f'   interpretation: {" ".join(interp_lines)}')
        print()

if total == 0:
    print('No open items in other sessions.')
PY
  ;;

migrate-items)
  # q migrate-items <dst-session-id> <sid8:n> [<sid8:n> ...]
  # Migrates specific items (by per-session number, full or 8-char UUID prefix) into dst
  [ $# -lt 2 ] && { echo "Usage: q migrate-items <session-id> <sid8:n> [...]" >&2; exit 1; }
  SID="$1"; shift; _validate_sid "$SID"

  python3 - "$SID" "$QUEUE_DIR" "$@" <<'PY'
import sys, re, os
from datetime import datetime, date

cur_sid, queue_dir = sys.argv[1], sys.argv[2]
refs = sys.argv[3:]
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
date_str = date.today().isoformat()
dst_path = os.path.join(queue_dir, cur_sid + '.md')

# Group refs by sid prefix → set of local item numbers
by_sid = {}
for ref in refs:
    parts = ref.split(':')
    if len(parts) != 2:
        print(f'Invalid ref (expected sid8:n): {ref}', file=sys.stderr); continue
    sid_prefix, n_str = parts[0], parts[1]
    if not sid_prefix:
        print(f'Invalid ref (empty sid): {ref}', file=sys.stderr); continue
    try:
        n = int(n_str)
    except ValueError:
        print(f'Invalid ref (non-integer n): {ref}', file=sys.stderr); continue
    by_sid.setdefault(sid_prefix, set()).add(n)

total = 0
for sid_prefix, item_nums in by_sid.items():
    # Match by full UUID or 8-char prefix
    matching = [f for f in os.listdir(queue_dir)
                if f.endswith('.md') and f != 'pending.md'
                and (f[:-3] == sid_prefix or f[:len(sid_prefix)] == sid_prefix)]
    if not matching:
        print(f'Session not found: {sid_prefix}'); continue
    src_path = os.path.join(queue_dir, matching[0])
    src_sid = matching[0][:-3]

    text = open(src_path).read()
    blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)

    local_n = 0
    new_src, fresh_items = [], []
    for block in blocks:
        if block.startswith('- [ ]'):
            local_n += 1
            if local_n in item_nums:
                cancelled = block.replace('- [ ]', '- [-]', 1)
                cancelled = re.sub(r'^  queued: [^\n]+', lambda m: f'{m.group()}\n  cancelled: {stamp}\n  reason: Moved after exit\n  moved-to: {cur_sid}', cancelled, count=1, flags=re.MULTILINE)
                new_src.append(cancelled)
                fresh_items.append(block.rstrip())
                total += 1
            else:
                new_src.append(block)
        else:
            new_src.append(block)

    if fresh_items:
        open(src_path, 'w').write(''.join(new_src))
        with open(dst_path, 'a') as f:
            f.write(f'\n# migrated from {src_sid} {date_str}\n')
            for item in fresh_items:
                f.write(item + '\n\n')

print(f'Migrated {total} item(s) to this session.' if total else 'No items migrated.')
PY
  ;;

needs-interpretation)
  # q needs-interpretation <session-id>
  # prints "<n>\t<ask>" for each open item missing an interpretation: line; empty = all have one
  SID="$1"; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"
  [ -f "$FILE" ] || exit 0
  python3 - "$FILE" <<'PY'
import sys, re

path = sys.argv[1]
text = open(path).read()
blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)

n = 0
for block in blocks:
    if not block.startswith('- [ ]'):
        continue
    n += 1
    if 'interpretation:' not in block:
        ask = block.split('\n')[0][6:]
        print(f'{n}\t{ask}')
PY
  ;;

write-interpretation)
  # q write-interpretation <session-id> <item-n> "<interpretation text>"
  SID="$1"; NUM="$2"; INTERP="$3"; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"
  [ -f "$FILE" ] || { echo "No queue file: $FILE"; exit 0; }
  python3 - "$FILE" "$NUM" "$INTERP" <<'PY'
import sys, re

path, num, interp = sys.argv[1], int(sys.argv[2]), sys.argv[3]
text = open(path).read()
blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)

n, result = 0, []
for block in blocks:
    if block.startswith('- [ ]'):
        n += 1
        if n == num and 'interpretation:' not in block:
            interp = interp.strip()
            if '\n' in interp:
                first, *rest = interp.split('\n')
                interp = first + ''.join(f'\n    {l}' for l in rest if l.strip())
            block = block.rstrip() + f'\n  interpretation: {interp}\n\n'
    result.append(block)

open(path, 'w').write(''.join(result))
PY
  ;;

mark-done)
  # q mark-done <session-id> <n|sid8:n> [...]
  # bare numbers → mark done in own session; sid8:n refs → mark done in source session
  SID="$1"; shift; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"
  python3 - "$FILE" "$QUEUE_DIR" "$@" <<'PY'
import sys, re, os
from datetime import datetime

path, queue_dir = sys.argv[1], sys.argv[2]
args = sys.argv[3:]
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

local_nums, by_sid = set(), {}
for arg in args:
    if ':' in arg:
        parts = arg.split(':')
        if len(parts) == 2:
            if not parts[0]:
                print(f'Invalid ref (empty sid): {arg}', file=sys.stderr)
            else:
                try:
                    by_sid.setdefault(parts[0], set()).add(int(parts[1]))
                except ValueError:
                    print(f'Invalid ref: {arg}', file=sys.stderr)
        else:
            print(f'Invalid ref (expected sid8:n): {arg}', file=sys.stderr)
    else:
        try:
            local_nums.add(int(arg))
        except ValueError:
            print(f'Invalid item number: {arg}', file=sys.stderr)

def mark_done_in(file_path, item_nums):
    if not os.path.isfile(file_path):
        print(f'No queue file: {file_path}'); return 0
    text = open(file_path).read()
    blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)
    n, result, count = 0, [], 0
    for block in blocks:
        if block.startswith('- [ ]'):
            n += 1
            if n in item_nums:
                block = block.replace('- [ ]', '- [x]', 1)
                block = re.sub(r'^  queued: [^\n]+', lambda m: m.group() + '\n  completed: ' + stamp, block, count=1, flags=re.MULTILINE)
                count += 1
        result.append(block)
    open(file_path, 'w').write(''.join(result))
    return count

total = 0
if local_nums:
    total += mark_done_in(path, local_nums)
for sid_prefix, item_nums in by_sid.items():
    matching = [f for f in os.listdir(queue_dir)
                if f.endswith('.md') and f != 'pending.md'
                and (f[:-3] == sid_prefix or f[:len(sid_prefix)] == sid_prefix)]
    if not matching:
        print(f'Session not found: {sid_prefix}'); continue
    total += mark_done_in(os.path.join(queue_dir, matching[0]), item_nums)

print(f'Marked done: {total} item(s).')
PY
  ;;

mark-cancelled)
  # q mark-cancelled <session-id> [--reason <text>] <n> [<n> ...]
  SID="$1"; shift; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"
  [ -f "$FILE" ] || { echo "No queue file: $FILE"; exit 0; }
  REASON="Cancelled"
  if [ "${1:-}" = "--reason" ]; then REASON="$2"; shift 2; fi
  python3 - "$FILE" "$REASON" "$@" <<'PY'
import sys, re
from datetime import datetime

path, reason = sys.argv[1], sys.argv[2]
nums = set(int(x) for x in sys.argv[3:])
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
text = open(path).read()
blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)

n, result = 0, []
for block in blocks:
    if block.startswith('- [ ]'):
        n += 1
        if n in nums:
            block = block.replace('- [ ]', '- [-]', 1)
            block = re.sub(r'^  queued: [^\n]+', lambda m: f'{m.group()}\n  cancelled: {stamp}\n  reason: {reason}', block, count=1, flags=re.MULTILINE)
    result.append(block)

open(path, 'w').write(''.join(result))
print(f'Cancelled: {sorted(nums)}')
PY
  ;;

clear)
  # q clear <session-id>  — mark open items [-] + park fresh copies in pending.md
  SID="$1"; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"; PENDING="$QUEUE_DIR/pending.md"
  [ -f "$FILE" ] || { echo "No queue file: $FILE"; exit 0; }
  python3 - "$FILE" "$PENDING" "$SID" <<'PY'
import sys, re
from datetime import datetime, date

src, pending, sid = sys.argv[1], sys.argv[2], sys.argv[3]
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
text = open(src).read()
blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)

new_src, pending_items = [], []
for block in blocks:
    if block.startswith('- [ ]'):
        cancelled = block.replace('- [ ]', '- [-]', 1)
        cancelled = re.sub(r'^  queued: [^\n]+', lambda m: f'{m.group()}\n  cancelled: {stamp}\n  reason: Moved after clear\n  moved-to: pending', cancelled, count=1, flags=re.MULTILINE)
        new_src.append(cancelled)
        # fresh copy: keep ask/sub-bullets/queued/priority/ctx, drop interpretation
        fresh, skip = [], False
        for line in block.split('\n'):
            s = line.lstrip()
            if s.startswith('interpretation:'):
                skip = True; continue
            if skip and line.startswith('    '):
                continue
            skip = False
            fresh.append(line)
        pending_items.append('\n'.join(fresh).rstrip())
    else:
        new_src.append(block)

open(src, 'w').write(''.join(new_src))
with open(pending, 'w') as f:
    f.write(f'# Pending from {sid} {date.today()}\n\n')
    for item in pending_items:
        f.write(item + '\n\n')

print(f'Cleared {len(pending_items)} item(s) → {pending}')
PY
  ;;

rename-pending)
  # q rename-pending <session-id>  — mv pending.md → <session-id>.md
  SID="$1"; _validate_sid "$SID"; PENDING="$QUEUE_DIR/pending.md"
  if [ -f "$PENDING" ]; then
    if [ -f "$QUEUE_DIR/$SID.md" ]; then
      # Session file already exists — append items (skip pending.md header line + blank)
      tail -n +3 "$PENDING" >> "$QUEUE_DIR/$SID.md"
      rm "$PENDING"
      echo "Merged pending.md → $SID.md"
    else
      mv "$PENDING" "$QUEUE_DIR/$SID.md"
      echo "Renamed pending.md → $SID.md"
    fi
  else
    echo "No pending.md."
  fi
  ;;


migrate)
  # q migrate <session-id> [src-session-id ...]  — cancel open items in other sessions, append fresh copies here
  # If source session IDs are given, only migrate those; otherwise migrate all
  SID="$1"; shift || true; _validate_sid "$SID"
  SRC_FILTER=("$@")
  DST="$QUEUE_DIR/$SID.md"
  total=0; sessions=0

  for src_file in "$QUEUE_DIR"/*.md; do
    [ -f "$src_file" ] || continue
    base=$(basename "$src_file" .md)
    [ "$base" = "$SID" ] && continue
    [ "$base" = "pending" ] && continue
    if [ "${#SRC_FILTER[@]}" -gt 0 ]; then
      found=0
      for s in "${SRC_FILTER[@]}"; do [ "$base" = "$s" ] && found=1 && break; done
      [ $found -eq 0 ] && continue
    fi

    n=$(python3 - "$src_file" "$DST" "$SID" "$base" <<'PY'
import sys, re
from datetime import datetime, date

src_path, dst_path, cur_sid, src_sid = sys.argv[1:5]
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
date_str = date.today().isoformat()
text = open(src_path).read()
blocks = re.split(r'(?=^- \[)', text, flags=re.MULTILINE)

new_src, fresh_items = [], []
for block in blocks:
    if block.startswith('- [ ]'):
        cancelled = block.replace('- [ ]', '- [-]', 1)
        cancelled = re.sub(r'^  queued: [^\n]+', lambda m: f'{m.group()}\n  cancelled: {stamp}\n  reason: Moved after exit\n  moved-to: {cur_sid}', cancelled, count=1, flags=re.MULTILINE)
        new_src.append(cancelled)
        fresh_items.append(block.rstrip())
    else:
        new_src.append(block)

if not fresh_items:
    print(0)
else:
    open(src_path, 'w').write(''.join(new_src))
    with open(dst_path, 'a') as f:
        f.write(f'\n# migrated from {src_sid} {date_str}\n')
        for item in fresh_items:
            f.write(item + '\n\n')
    print(len(fresh_items))
PY
    )
    [ "${n:-0}" -gt 0 ] && { total=$((total + n)); sessions=$((sessions + 1)); } || true
  done

  [ "$total" -gt 0 ] && \
    printf 'Migrated %d item(s) from %d session(s) into this session. Run /queue to review.\n' "$total" "$sessions" \
    || true
  ;;

*)
  echo "Usage: q <add|list|list-other|needs-interpretation|write-interpretation|mark-done|mark-cancelled|clear|rename-pending|migrate|migrate-items> ..." >&2
  exit 1
  ;;
esac
