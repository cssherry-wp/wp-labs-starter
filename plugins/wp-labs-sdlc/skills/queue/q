#!/usr/bin/env bash
# queue helper — deterministic file I/O for the /queue skill
# usage: q <add|list|list-other|needs-interpretation|write-interpretation|mark-done|mark-cancelled|clear|rename-pending|migrate-items> ...
set -euo pipefail

QUEUE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/queue"
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
mkdir -p "$QUEUE_DIR"

# Guard against path traversal via a caller-supplied session id.
# UUIDs only use alphanumerics and hyphens; nothing else is valid.
_validate_sid() {
  local sid="$1"
  [ -z "$sid" ] && return 0
  [[ "$sid" =~ ^[a-zA-Z0-9_-]+$ ]] || { printf 'Invalid session id: %s\n' "$sid" >&2; exit 1; }
}

cmd="${1:-}"; shift || true

case "$cmd" in

add)
  # q add <session-id> [--group <name>] [--high|--med|--low] "<ask>" "<ctx>"
  SID="$1"; shift; _validate_sid "$SID"
  GROUP="" PRI=""
  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --high)  PRI=high;   shift   ;;
      --med)   PRI=med;    shift   ;;
      --low)   PRI=low;    shift   ;;
      --group) GROUP="$2"; shift 2 ;;
      *)       break               ;;
    esac
  done
  ASK="${1:-}"; CTX="${2:-$(pwd)}"
  FILE="$QUEUE_DIR/$SID.md"
  STAMP=$(date '+%Y-%m-%d %H:%M:%S')

  FIRST=$(printf '%s' "$ASK" | head -1)
  REST=$(printf '%s' "$ASK" | tail -n +2)

  {
    printf -- '- [ ] %s\n' "$FIRST"
    if [ -n "$REST" ]; then
      while IFS= read -r ln; do
        [ -n "$ln" ] && printf '  - %s\n' "$ln"
      done <<< "$REST"
    fi
    printf '  queued: %s\n' "$STAMP"
    [ -n "$PRI" ]   && printf '  priority: %s\n' "$PRI"
    [ -n "$GROUP" ] && printf '  group: %s\n' "$GROUP"
    printf '  ctx: %s\n' "$(basename "$CTX")"
    printf '\n'
  } >> "$FILE"

  N=$(grep -c '^\- \[ \]' "$FILE" 2>/dev/null || echo 0)
  printf 'Queued (%d in backlog) → %s\n' "$N" "$FILE"
  ;;

list|list-other)
  OTHER=0; [ "$cmd" = "list-other" ] && OTHER=1
  if [ $OTHER -eq 0 ]; then
    ONELINE=0
    [ "${1:-}" = "--oneline" ] && { ONELINE=1; shift; }
    SID="${1:-}"; [ -n "$SID" ] && shift
    [ "${1:-}" = "--oneline" ] && { ONELINE=1; shift; }
    GROUP_FILTER=""
    [ "${1:-}" = "--group" ] && { GROUP_FILTER="$2"; shift 2; }
    if [ -n "$SID" ]; then
      FILE="$QUEUE_DIR/$SID.md"
      [ -f "$FILE" ] || { echo "No queue file: $FILE"; exit 1; }
      FILES=("$FILE")
    else
      shopt -s nullglob; FILES=("$QUEUE_DIR"/*.md); shopt -u nullglob
      [ ${#FILES[@]} -eq 0 ] && { echo "No queue files."; exit 0; }
    fi
  else
    SID="${1:-}"; shift || true
    ONELINE=0
    [ "${1:-}" = "--oneline" ] && { ONELINE=1; shift; }
    GROUP_FILTER=""
    [ "${1:-}" = "--group" ] && { GROUP_FILTER="$2"; shift 2; }
    shopt -s nullglob; FILES=("$QUEUE_DIR"/*.md); shopt -u nullglob
    [ ${#FILES[@]} -eq 0 ] && { echo "No queue files."; exit 0; }
  fi
  python3 - "$SCRIPT_DIR" "$OTHER" "$ONELINE" "$SID" "$GROUP_FILTER" "${FILES[@]}" <<'PY'
import sys, os
sys.path.insert(0, sys.argv[1])
from _qlib import split_blocks, parse_block_meta

other_mode   = sys.argv[2] == '1'
oneline      = sys.argv[3] == '1'
cur_sid      = sys.argv[4]
group_filter = sys.argv[5]
files        = [f for f in sys.argv[6:] if os.path.isfile(f)]

total = 0
for path in files:
    sid = os.path.basename(path)[:-3]
    if sid == 'pending': continue
    if other_mode and sid == cur_sid: continue
    if not other_mode and cur_sid and sid != cur_sid: continue

    text = open(path).read()
    open_blocks = [b for b in split_blocks(text) if b.startswith('- [ ]')]
    if not open_blocks: continue

    printed_header = False
    for local_n, block in enumerate(open_blocks, 1):
        lines = block.strip().split('\n')
        ask = lines[0][6:]
        meta, sub, interp_lines = parse_block_meta(lines[1:])

        if group_filter and meta.get('group', '') != group_filter:
            continue

        total += 1
        if not printed_header and not oneline:
            if other_mode:
                print(f'## {sid}  ({len(open_blocks)} item{"s" if len(open_blocks)!=1 else ""})\n')
            elif not cur_sid:
                print(f'## {sid}\n')
            printed_header = True

        if oneline:
            if other_mode:
                print(f'{total}. {sid[:8]}: {ask}  [{sid[:8]}:{local_n}]')
            else:
                pfx = f'{sid[:8]}: ' if not cur_sid else ''
                print(f'{pfx}{ask}')
            continue

        badge = {'high': '[H]', 'med': '[M]', 'low': '[L]'}.get(meta.get('priority', ''), '')
        grp   = f'[{meta["group"]}] ' if meta.get('group') else ''
        pfx   = f'{badge} ' if badge else ''
        ref   = f'  [{sid[:8]}:{local_n}]' if other_mode else ''
        print(f'{total}. {pfx}{grp}{ask}{ref}')
        for s in sub: print(f'   • {s}')
        print(f'   queued: {meta.get("queued", "?")}')
        if interp_lines: print(f'   interpretation: {" ".join(interp_lines)}')
        print()

if total == 0:
    print('No open items in other sessions.' if other_mode else 'No open items.')
    sys.exit(1)
PY
  ;;

migrate-items)
  # q migrate-items <dst-session-id> <sid8:n> [<sid8:n> ...]
  # Migrates specific items (by per-session number, full or 8-char UUID prefix) into dst
  [ $# -lt 2 ] && { echo "Usage: q migrate-items <session-id> <sid8:n> [...]" >&2; exit 1; }
  SID="$1"; shift; _validate_sid "$SID"

  python3 - "$SCRIPT_DIR" "$SID" "$QUEUE_DIR" "$@" <<'PY'
import sys, re, os
from datetime import datetime, date
sys.path.insert(0, sys.argv[1])
from _qlib import split_blocks, cancel_block

cur_sid, queue_dir = sys.argv[2], sys.argv[3]
refs = sys.argv[4:]
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
date_str = date.today().isoformat()
dst_path = os.path.join(queue_dir, cur_sid + '.md')

by_sid = {}
for ref in refs:
    parts = ref.split(':')
    if len(parts) != 2:
        print(f'Invalid ref (expected sid8:n): {ref}', file=sys.stderr); continue
    sid_prefix, n_str = parts[0], parts[1]
    if not sid_prefix:
        print(f'Invalid ref (empty sid): {ref}', file=sys.stderr); continue
    try:
        n = int(n_str)
    except ValueError:
        print(f'Invalid ref (non-integer n): {ref}', file=sys.stderr); continue
    by_sid.setdefault(sid_prefix, set()).add(n)

total = 0
for sid_prefix, item_nums in by_sid.items():
    matching = [f for f in os.listdir(queue_dir)
                if f.endswith('.md') and f != 'pending.md'
                and (f[:-3] == sid_prefix or f[:len(sid_prefix)] == sid_prefix)]
    if not matching:
        print(f'Session not found: {sid_prefix}'); continue
    src_path = os.path.join(queue_dir, matching[0])
    src_sid = matching[0][:-3]

    text = open(src_path).read()
    blocks = split_blocks(text)

    local_n, new_src, fresh_items = 0, [], []
    for block in blocks:
        if block.startswith('- [ ]'):
            local_n += 1
            if local_n in item_nums:
                new_src.append(cancel_block(block, stamp, 'Moved after exit', cur_sid))
                fresh_items.append(block.rstrip())
                total += 1
            else:
                new_src.append(block)
        else:
            new_src.append(block)

    if fresh_items:
        open(src_path, 'w').write(''.join(new_src))
        with open(dst_path, 'a') as f:
            f.write(f'\n# migrated from {src_sid} {date_str}\n')
            for item in fresh_items:
                f.write(item + '\n\n')

print(f'Migrated {total} item(s) to this session.' if total else 'No items migrated.')
PY
  ;;

needs-interpretation)
  # q needs-interpretation <session-id>
  # prints "<n>\t<ask>" for each open item missing an interpretation: line; empty = all have one
  SID="$1"; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"
  [ -f "$FILE" ] || exit 0
  python3 - "$SCRIPT_DIR" "$FILE" <<'PY'
import sys
sys.path.insert(0, sys.argv[1])
from _qlib import split_blocks

path = sys.argv[2]
text = open(path).read()

n = 0
for block in split_blocks(text):
    if not block.startswith('- [ ]'):
        continue
    n += 1
    if 'interpretation:' not in block:
        ask = block.split('\n')[0][6:]
        print(f'{n}\t{ask}')
PY
  ;;

write-interpretation)
  # q write-interpretation <session-id> <item-n> "<interpretation text>"
  SID="$1"; NUM="$2"; INTERP="$3"; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"
  [ -f "$FILE" ] || { echo "No queue file: $FILE"; exit 0; }
  python3 - "$SCRIPT_DIR" "$FILE" "$NUM" "$INTERP" <<'PY'
import sys
sys.path.insert(0, sys.argv[1])
from _qlib import split_blocks

path, num, interp = sys.argv[2], int(sys.argv[3]), sys.argv[4]
text = open(path).read()

n, result = 0, []
for block in split_blocks(text):
    if block.startswith('- [ ]'):
        n += 1
        if n == num and 'interpretation:' not in block:
            interp = interp.strip()
            if '\n' in interp:
                first, *rest = interp.split('\n')
                interp = first + ''.join(f'\n    {l}' for l in rest if l.strip())
            block = block.rstrip() + f'\n  interpretation: {interp}\n\n'
    result.append(block)

open(path, 'w').write(''.join(result))
PY
  ;;

mark-done)
  # q mark-done <session-id> <n|sid8:n> [...]
  # bare numbers → mark done in own session; sid8:n refs → mark done in source session
  SID="$1"; shift; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"
  python3 - "$SCRIPT_DIR" "$FILE" "$QUEUE_DIR" "$@" <<'PY'
import sys, re, os
from datetime import datetime
sys.path.insert(0, sys.argv[1])
from _qlib import split_blocks

path, queue_dir = sys.argv[2], sys.argv[3]
args = sys.argv[4:]
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

local_nums, by_sid = set(), {}
for arg in args:
    if ':' in arg:
        parts = arg.split(':')
        if len(parts) == 2:
            if not parts[0]:
                print(f'Invalid ref (empty sid): {arg}', file=sys.stderr)
            else:
                try:
                    by_sid.setdefault(parts[0], set()).add(int(parts[1]))
                except ValueError:
                    print(f'Invalid ref: {arg}', file=sys.stderr)
        else:
            print(f'Invalid ref (expected sid8:n): {arg}', file=sys.stderr)
    else:
        try:
            local_nums.add(int(arg))
        except ValueError:
            print(f'Invalid item number: {arg}', file=sys.stderr)

def mark_done_in(file_path, item_nums):
    if not os.path.isfile(file_path):
        print(f'No queue file: {file_path}'); return 0
    text = open(file_path).read()
    n, result, count = 0, [], 0
    for block in split_blocks(text):
        if block.startswith('- [ ]'):
            n += 1
            if n in item_nums:
                block = block.replace('- [ ]', '- [x]', 1)
                block = re.sub(r'^  queued: [^\n]+', lambda m: m.group() + '\n  completed: ' + stamp, block, count=1, flags=re.MULTILINE)
                count += 1
        result.append(block)
    open(file_path, 'w').write(''.join(result))
    return count

total = 0
if local_nums:
    total += mark_done_in(path, local_nums)
for sid_prefix, item_nums in by_sid.items():
    matching = [f for f in os.listdir(queue_dir)
                if f.endswith('.md') and f != 'pending.md'
                and (f[:-3] == sid_prefix or f[:len(sid_prefix)] == sid_prefix)]
    if not matching:
        print(f'Session not found: {sid_prefix}'); continue
    total += mark_done_in(os.path.join(queue_dir, matching[0]), item_nums)

print(f'Marked done: {total} item(s).')
PY
  ;;

mark-cancelled)
  # q mark-cancelled <session-id> [--reason <text>] <n> [<n> ...]
  SID="$1"; shift; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"
  [ -f "$FILE" ] || { echo "No queue file: $FILE"; exit 0; }
  REASON="Cancelled"
  if [ "${1:-}" = "--reason" ]; then REASON="$2"; shift 2; fi
  python3 - "$SCRIPT_DIR" "$FILE" "$REASON" "$@" <<'PY'
import sys, re
from datetime import datetime
sys.path.insert(0, sys.argv[1])
from _qlib import split_blocks, cancel_block

path, reason = sys.argv[2], sys.argv[3]
nums = set(int(x) for x in sys.argv[4:])
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

n, result = 0, []
for block in split_blocks(open(path).read()):
    if block.startswith('- [ ]'):
        n += 1
        if n in nums:
            block = cancel_block(block, stamp, reason)
    result.append(block)

open(path, 'w').write(''.join(result))
print(f'Cancelled: {sorted(nums)}')
PY
  ;;

clear)
  # q clear <session-id>  — mark open items [-] + park fresh copies in pending.md
  SID="$1"; _validate_sid "$SID"; FILE="$QUEUE_DIR/$SID.md"; PENDING="$QUEUE_DIR/pending.md"
  [ -f "$FILE" ] || { echo "No queue file: $FILE"; exit 0; }
  python3 - "$SCRIPT_DIR" "$FILE" "$PENDING" "$SID" <<'PY'
import sys, re
from datetime import datetime, date
sys.path.insert(0, sys.argv[1])
from _qlib import split_blocks, cancel_block

src, pending, sid = sys.argv[2], sys.argv[3], sys.argv[4]
stamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

new_src, pending_items = [], []
for block in split_blocks(open(src).read()):
    if block.startswith('- [ ]'):
        new_src.append(cancel_block(block, stamp, 'Moved after clear', 'pending'))
        pending_items.append(block.rstrip())
    else:
        new_src.append(block)

open(src, 'w').write(''.join(new_src))
with open(pending, 'w') as f:
    f.write(f'# Pending from {sid} {date.today()}\n\n')
    for item in pending_items:
        f.write(item + '\n\n')

print(f'Cleared {len(pending_items)} item(s) → {pending}')
PY
  ;;

rename-pending)
  # q rename-pending <session-id>  — mv pending.md → <session-id>.md
  SID="$1"; _validate_sid "$SID"; PENDING="$QUEUE_DIR/pending.md"
  if [ -f "$PENDING" ]; then
    if [ -f "$QUEUE_DIR/$SID.md" ]; then
      # Session file already exists — append items (skip pending.md header line + blank)
      tail -n +3 "$PENDING" >> "$QUEUE_DIR/$SID.md"
      rm "$PENDING"
      echo "Merged pending.md → $SID.md"
    else
      mv "$PENDING" "$QUEUE_DIR/$SID.md"
      echo "Renamed pending.md → $SID.md"
    fi
  else
    echo "No pending.md."
  fi
  ;;

write-group)
  # q write-group <session-id> <item-n> "<group name>"  — assigns or overwrites group on item N
  SID="$1"; NUM="$2"; GROUP="$3"; FILE="$QUEUE_DIR/$SID.md"
  [ -f "$FILE" ] || { echo "No queue file: $FILE" >&2; exit 1; }
  python3 - "$SCRIPT_DIR" "$FILE" "$NUM" "$GROUP" <<'PY'
import sys
sys.path.insert(0, sys.argv[1])
from _qlib import write_group
write_group(sys.argv[2], int(sys.argv[3]), sys.argv[4])
PY
  ;;

*)
  echo "Usage: q <add|list|list-other|needs-interpretation|write-interpretation|write-group|mark-done|mark-cancelled|clear|rename-pending|migrate-items> ..." >&2
  exit 1
  ;;
esac
