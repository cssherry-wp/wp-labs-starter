#!/usr/bin/env bash
# Queue interceptor: all /queue commands route through here first.
# - Capture (A) and list (C): block LLM, handle directly
# - Drain (B) and migrate (D): pre-fetch q data, inject context, let LLM handle
# - Setup: pass through to LLM
set -euo pipefail
command -v jq >/dev/null 2>&1 || exit 0

_in=$(cat)
_prompt=$(printf '%s' "$_in" | jq -r '.prompt // empty' 2>/dev/null || true)
_sid=$(printf '%s' "$_in" | jq -r '.session_id // empty' 2>/dev/null || true)

# Intercept bare /queue and /queue <args>
[[ "$_prompt" == "/queue" ]] || [[ "$_prompt" =~ ^/queue\  ]] || exit 0

_q="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/queue/q"
[ -x "$_q" ] || exit 0

if [[ "$_prompt" == "/queue" ]]; then
  # Mode B: drain — inject queue state so Claude can handle selection and execution
  _list=$("$_q" list "$_sid" 2>&1 || true)
  _needs=$("$_q" needs-interpretation "$_sid" 2>&1 || true)
  if [ -n "$_needs" ]; then
    jq -n --arg list "$_list" --arg needs "$_needs" \
      '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":
        ("Queue state (do not re-fetch):\n\n"+$list+"\n\nNeeding interpretation:\n"+$needs)}}'
  else
    jq -n --arg list "$_list" \
      '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":
        ("Queue state (do not re-fetch):\n\n"+$list)}}'
  fi
  exit 0
fi

_args="${_prompt#/queue }"

case "$_args" in
  list*)
    # Mode C: block LLM — show list directly
    _result=$("$_q" list "$_sid" 2>&1 || true)
    jq -n --arg r "$_result" '{"decision":"block","reason":$r}'
    ;;
  migrate*)
    # Mode D: inject other-session items so Claude can handle interactive selection
    _others=$("$_q" list-other "$_sid" 2>&1 || true)
    jq -n --arg ctx "Other session items (do not re-fetch):\n\n${_others}" \
      '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":$ctx}}'
    ;;
  setup*)
    exit 0
    ;;
  *)
    # Mode A: capture — block LLM entirely
    _pri=""
    case "$_args" in
      "--high "*) _pri="--high"; _args="${_args#--high }" ;;
      "--med "*)  _pri="--med";  _args="${_args#--med }"  ;;
      "--low "*)  _pri="--low";  _args="${_args#--low }"  ;;
    esac
    _result=$("$_q" add "$_sid" ${_pri:+"$_pri"} "$_args" "$(pwd)" 2>&1)
    jq -n --arg r "$_result" '{"decision":"block","reason":$r}'
    ;;
esac
